PORT=3000
SITE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Pegue este token no painel de credenciais do Mercado Pago.
# Nunca coloque esse token no HTML, CSS, JS publico ou no GitHub.
MERCADO_PAGO_ACCESS_TOKEN=APP_USR_SEU_ACCESS_TOKEN_AQUI

# Use uma string longa e aleatoria em producao.
DOWNLOAD_TOKEN_SECRET=troque-por-uma-chave-grande-e-secreta

# Token para abrir admin.html e chamar /api/admin/*.
ADMIN_TOKEN=troque-por-uma-chave-admin-grande

# Token fixo que o instalador Windows envia em X-Installer-Token.
# Nao coloque o token real em repositorio publico.
INSTALLER_API_TOKEN=troque-por-uma-chave-do-instalador
INSTALLER_DEFAULT_MOD_ID=asm-8r

# Use true quando estiver usando credenciais de teste.
MERCADO_PAGO_USE_SANDBOX=true

# Em producao, configure uma URL publica para receber notificacoes.
# Exemplo: https://sua-api.onrender.com/api/payments/webhook
MERCADO_PAGO_WEBHOOK_URL=

# Pasta fora do site publico onde ficam os ZIPs dos mods.
DATA_DIR=data
PRIVATE_DOWNLOADS_DIR=private-downloads

# Email automatico do codigo de acesso. Opcional.
# Crie uma chave em https://resend.com e valide o dominio/remetente.
RESEND_API_KEY=
EMAIL_FROM="AGRO SCRIPT MODDING <suporte@seudominio.com>"
